# =============================================================================
# Karta SDR - Environment Configuration
# =============================================================================

# Application
APP_NAME=Karta SDR
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-to-a-secure-random-string

# Supabase PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/karta_sdr
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Gemini LLM
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_TOKENS=512

# Whisper STT
WHISPER_MODEL=whisper-1
WHISPER_API_KEY=your-openai-api-key
# Or use local whisper
WHISPER_USE_LOCAL=false
WHISPER_LOCAL_MODEL=base

# Edge TTS
EDGE_TTS_VOICE=en-US-AriaNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz

# Voice Orchestration (vapi | livekit)
VOICE_PROVIDER=vapi

# Vapi
VAPI_API_KEY=your-vapi-api-key
VAPI_ASSISTANT_ID=your-vapi-assistant-id
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# LiveKit
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Google Sheets CRM
GOOGLE_SHEETS_CREDENTIALS_PATH=./credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SHEETS_WORKSHEET_NAME=Leads

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS_PATH=./credentials.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/New_York
BOOKING_DURATION_MINUTES=30
BOOKING_BUFFER_MINUTES=15

# Lead Scoring Thresholds
SCORE_UNQUALIFIED_MAX=40
SCORE_WARM_MAX=80
SCORE_SQL_MAX=120

# Conversation Settings
MAX_SILENCE_SECONDS=5
BARGE_IN_ENABLED=true
INTERRUPTION_GRACE_MS=300
CONVERSATION_TIMEOUT_SECONDS=1800
FAQ_DETOUR_MAX_TURNS=3

# Analytics
COST_PER_MINUTE_USD=0.08
COST_PER_LLM_TOKEN_USD=0.000001

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Frontend — Vapi Web SDK (Vite: VITE_* or NEXT_PUBLIC_*)
VITE_VAPI_PUBLIC_KEY=your-vapi-public-key
VITE_VAPI_ASSISTANT_ID=your-vapi-assistant-id
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your-vapi-assistant-id

# Redis (optional, for session cache)
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false
